@{
    ViewData["Title"] = "WorkExperience";
}

<div class="content-box work-container">

    <h1 class="work-title">Work Experience</h1>

    <div class="work-photo-frame">
        <img src="~/images/pic2.jpg" alt="Work Photo" class="work-photo">
    </div>

    <hr class="about-divider" />


    <section class="timeline-section">
        <h2 class="section-title">🕒 My Work Journey</h2>

        <div class="timeline">

            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <h3>🛒 Cashier — Supermarket</h3>
                    <p><strong>Duration:</strong> 2022</p>
                    <ul>
                        <li>Handled daily transactions efficiently and accurately.</li>
                        <li>Maintained customer satisfaction through friendly service.</li>
                        <li>Assisted in inventory arrangement and restocking.</li>
                    </ul>
                </div>
            </div>

            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <h3>🛍 Salesperson</h3>
                    <p><strong>Duration:</strong> 2022 – 2023</p>
                    <ul>
                        <li>Provided product recommendations and guided customers.</li>
                        <li>Achieved monthly sales targets consistently.</li>
                        <li>Managed basic product display and customer inquiries.</li>
                    </ul>
                </div>
            </div>


            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <h3>🚗 IoT Project — Autonomous Drive Robotic Vehicle</h3>
                    <p><strong>Duration:</strong> University Project</p>
                    <ul>
                        <li>Participated in IoT sensor module design.</li>
                        <li>Assisted in building logic for automatic movement detection.</li>
                        <li>Worked in a team to integrate hardware with control software.</li>
                    </ul>
                </div>
            </div>


            <div class="timeline-item future-item">
                <div class="timeline-dot future-dot"></div>
                <div class="timeline-content">
                    <h3>✨ Future Experience</h3>
                </div>
            </div>

        </div>
    </section>

</div>
