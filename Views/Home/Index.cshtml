@{
    ViewData["Title"] = "Home Page";
}

<div class="content-box">
    <img src="~/images/pic1.jpg" alt="Profile Image" class="profile-photo" />

    <h2 class="centered-paragraph">
        Welcome to my personal website!
    </h2>

    <p class="centered-paragraph">
        I am a passionate computing student who enjoys learning and building simple, clean, and user-friendly web applications. 
        This website shares a little about who I am, my background, and how to reach me.
    </p>

    <section class="skills-section">
        <h2 class="skills-title">My Key Skills</h2>
        <div class="skills-container">

            <div class="skill-card">
                <h3>Web Development</h3>
                <p>Basic understanding of ASP.NET Core, HTML, CSS, and JavaScript. I enjoy creating clean and simple web pages.</p>
            </div>

            <div class="skill-card">
                <h3>Programming</h3>
                <p>Experience in C#, Java, and Python through university projects and coursework.</p>
            </div>

            <div class="skill-card">
                <h3>Problem Solving</h3>
                <p>I enjoy learning new technologies, experimenting with ideas, and solving real-world problems through code.</p>
            </div>

        </div>
    </section>
</div>